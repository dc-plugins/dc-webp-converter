msgid "<strong>PNG → WebP Converter:</strong> Run the <a href=\"%s\">server requirements check</a> before starting conversion."
msgstr "<strong>PNG → WebP Konverter:</strong> Führe die <a href=\"%s\">Serveranforderungsprüfung</a> durch, bevor du beginnst."

msgid "<strong>PNG → WebP Converter:</strong> Your server does not meet all requirements. <a href=\"%s\">View details</a>."
msgstr "<strong>PNG → WebP Konverter:</strong> Dein Server erfüllt nicht alle Anforderungen. <a href=\"%s\">Details anzeigen</a>."

msgid "Server Requirements"
msgstr "Serveranforderungen"

msgid "✓ Server qualifies"
msgstr "✓ Server erfüllt Anforderungen"

msgid "✗ Server does not qualify"
msgstr "✗ Server erfüllt Anforderungen nicht"

